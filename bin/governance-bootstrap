#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="${DOCS_AS_CODE_PYTHON:-python3}"
JSON_REQUESTED=false

for arg in "$@"; do
    if [[ "$arg" == "--json" ]]; then
        JSON_REQUESTED=true
        break
    fi
done

bootstrap_runtime_failure() {
    local error_code="$1"
    local message="$2"
    local status="$3"
    if [[ "$JSON_REQUESTED" == true ]]; then
        printf '{"ok":false,"error_code":"%s","error":"%s","can_continue":false,"writes_state":false,"repair":{"kind":"manual-runtime-repair","tool":"python","minimum_version":"3.10","environment_override":"DOCS_AS_CODE_PYTHON"}}\n' "$error_code" "$message"
    else
        printf 'governance bootstrap: %s\n' "$message" >&2
        printf 'Install Python 3.10 or newer, or set DOCS_AS_CODE_PYTHON to a compatible interpreter.\n' >&2
    fi
    exit "$status"
}

if ! command -v "$PYTHON_BIN" >/dev/null 2>&1; then
    bootstrap_runtime_failure \
        "bootstrap_python_unavailable" \
        "Python 3.10 or newer is required before governance bootstrap can inspect or repair the remaining environment." \
        127
fi

if ! "$PYTHON_BIN" -c 'import sys; raise SystemExit(0 if sys.version_info[:2] >= (3, 10) else 1)' >/dev/null 2>&1; then
    bootstrap_runtime_failure \
        "bootstrap_python_incompatible" \
        "The selected Python interpreter is unavailable, broken, or older than 3.10." \
        2
fi

exec "$PYTHON_BIN" "$ROOT_DIR/scripts/bootstrap_consumer_project.py" --auto-repair-env "$@"
